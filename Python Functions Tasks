#Task - Create a function to check whether a number is prime.

def prime(x):
    isprime=True
    for i in range(2,x):
        if x%i==0:
            isprime=False
    if isprime:
        print(f"{x} is prime")
    else:
        print(f"{x} is not prime")
prime(11)


