#Task - Recursive function to find LCM.

def gcd(a,b):
    if b == 0:
        return a
    return gcd(b, a % b)

def lcm(a, b):
    if a == 0 or b == 0:
        return 0
    return abs(a * b) // gcd(a, b)
print(lcm(45,24))


#Task - Recursive function to calculate sum of digits.

def d_sum(n):
    if n == 0:
        return 0
    return (n % 10) + d_sum(n // 10)
print(d_sum(45678))
