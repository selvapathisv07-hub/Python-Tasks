#Task - Function to check Armstrong number.

def armstrong(n):
    a=str(n)
    l=len(a)
    c=0
    for i in a:
        c+=int(i)**l
    if c==int(a):
        print("It is a armstrong number")
    else:
        print("It is not a armstrong number")
armstrong(153)


