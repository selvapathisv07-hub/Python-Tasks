#Task - ATM balance check / withdraw / deposit options

ATM=516521
print(f"The ATM balance is {ATM}")
user_atm=input("Enter the method: ")
if user_atm=="withdraw":
    withdraw=int(input("Enter the amount: "))
    ATM=ATM-withdraw
    print(f"The balance amount is {ATM}")
elif user_atm=="deposit":
    deposit=int(input("Enter the amount: "))
    ATM+=deposit
    print(f"The balance amount is {ATM}")


