#Task - Write a Python program that accepts a string and calculates the number of digits and letters.

string=input("Enter a word: ")
dig=0
alph=0
for i in string:
    if i.isalpha():
        alph+=1
    elif i.isdigit():
        dig+=1
print("The number of digits in the word is",dig)
print("The number of letter in the word is",alph)

